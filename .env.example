# ============================================================
# Havoc Security — Environment Variables
# COPY this file to .env and fill in your real values.
# NEVER commit .env to Git.
# ============================================================

# ── Stripe Payment Keys ────────────────────────────────────
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_KEY

# Stripe Price IDs — create products at:
# https://dashboard.stripe.com/products
STRIPE_STARTER_PRICE_ID=price_REPLACE_STARTER
STRIPE_PRO_PRICE_ID=price_REPLACE_PRO
STRIPE_TEAM_PRICE_ID=price_REPLACE_TEAM

# Stripe Webhook Signing Secret
# For local dev: run `stripe listen --forward-to localhost:5000/api/billing/webhook`
# For production: create webhook at https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_WEBHOOK_SECRET

# ── Frontend URL (for Stripe redirect after payment) ───────
# Local development:
FRONTEND_URL=http://localhost:5173
# Production (Vercel):
# FRONTEND_URL=https://your-app.vercel.app

# ── JWT Security ────────────────────────────────────────────
# Generate a strong random secret:
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=REPLACE_WITH_RANDOM_64_CHAR_STRING

# ── Optional: Flask Environment ─────────────────────────────
FLASK_ENV=development
